{
    "name": "aicleaner",
    "version": "1.0.0",
    "description": "AI-driven space cleaning desktop app powered by Tauri v2 and Rust",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "typecheck": "tsc --noEmit",
        "test:frontend": "vitest run",
        "test": "vitest run",
        "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
        "check:frontend": "npm run typecheck && npm test && npm run build",
        "check:all": "npm run check:frontend && npm run test:rust",
        "build": "vite build",
        "tauri": "tauri",
        "tauri:dev": "node scripts/tauri-dev.mjs",
        "tauri:build": "tauri build",
        "start": "npm run tauri:dev"
    },
    "dependencies": {
        "@tauri-apps/api": "^2.8.0",
        "@tauri-apps/plugin-dialog": "^2.6.0",
        "@tauri-apps/plugin-stronghold": "^2.3.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.10.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "jsdom": "^29.1.0",
        "typescript": "^6.0.3",
        "vite": "^6.0.0",
        "vitest": "^4.1.5"
    }
}
